              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"دكتور أحمد\",\n  \"phone\": \"0791234567\",\n  \"email\": \"ahmed@doctor.com\",\n  \"password\": \"Password123\",\n  \"role\": \"doctor\",\n  \"buildNo\": \"5\",\n  \"floorNo\": \"3\",\n  \"address\": \"عمان، الأردن\"\n}"
            },
            "url": {
